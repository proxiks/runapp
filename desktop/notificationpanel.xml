<UserControl x:Class="RunApp.Desktop.Views.NotificationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="380" MaxHeight="600">

    <Border Background="#242526" 
            CornerRadius="12" 
            BorderBrush="#3A3B3C" 
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="#242526" 
                    CornerRadius="12,12,0,0"
                    Padding="16,12">
                <Grid>
                    <TextBlock Text="Notifications" 
                             FontSize="18" 
                             FontWeight="Bold" 
                             Foreground="White"/>
                    <Button Content="✕" 
                          Click="OnClose"
                          HorizontalAlignment="Right"
                          Style="{StaticResource GhostButtonStyle}"/>
                </Grid>
            </Border>

            <!-- Notification List -->
            <ScrollViewer Grid.Row="1" 
                        VerticalScrollBarVisibility="Auto"
                        Margin="0,0,0,0">
                <ItemsControl x:Name="NotificationList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding IsRead, Converter={StaticResource ReadToBrush}}"
                                  Padding="12,10"
                                  BorderBrush="#3A3B3C"
                                  BorderThickness="0,0,0,1"
                                  Cursor="Hand"
                                  MouseDown="OnNotificationClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Grid.Column="0" 
                                          Width="40" 
                                          Height="40" 
                                          CornerRadius="20"
                                          Background="{Binding Type, Converter={StaticResource TypeToBrush}}"
                                          Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Icon}" 
                                                 FontSize="20" 
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Content -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}" 
                                                 FontWeight="SemiBold" 
                                                 Foreground="White"
                                                 TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Message}" 
                                                 Foreground="#B0B3B8"
                                                 FontSize="13"
                                                 TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding TimeAgo}" 
                                                 Foreground="#65676B"
                                                 FontSize="11"
                                                 Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Unread dot -->
                                    <Ellipse Grid.Column="2" 
                                           Width="8" 
                                           Height="8" 
                                           Fill="#1877F2"
                                           Visibility="{Binding IsRead, Converter={StaticResource UnreadToVisibility}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" 
                    Background="#242526" 
                    CornerRadius="0,0,12,12"
                    Padding="16,12"
                    BorderBrush="#3A3B3C"
                    BorderThickness="0,1,0,0">
                <Button Content="Mark all as read" 
                      Click="OnMarkAllRead"
                      HorizontalAlignment="Center"
                      Foreground="#1877F2"
                      FontWeight="SemiBold"
                      Style="{StaticResource TextButtonStyle}"/>
            </Border>
        </Grid>
    </Border>
</UserControl>