<Window x:Class="RunApp.Desktop.Views.ReelsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RunApp - Reels"
        WindowState="Maximized"
        Background="Black">

    <Grid>
        <!-- Video Player -->
        <MediaElement x:Name="VideoPlayer"
                     LoadedBehavior="Play"
                     UnloadedBehavior="Stop"
                     Stretch="Uniform"/>

        <!-- Overlay -->
        <Grid VerticalAlignment="Bottom" Margin="20,0,80,40">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#CC000000" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel Margin="16">
                <TextBlock x:Name="UserNameText" 
                         Text="@jatin" 
                         FontWeight="Bold" 
                         FontSize="16"
                         Foreground="White"/>
                <TextBlock x:Name="CaptionText" 
                         Text="Lyfron security in action 🔒" 
                         FontSize="14"
                         Foreground="#DDFFFFFF"
                         TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!-- Right Actions -->
        <StackPanel HorizontalAlignment="Right" 
                   VerticalAlignment="Bottom" 
                   Margin="0,0,16,100">
            <Button Style="{StaticResource ReelActionStyle}" Click="OnLike">
                <StackPanel>
                    <TextBlock Text="♥" FontSize="28"/>
                    <TextBlock x:Name="LikeCount" Text="1.2K" FontSize="12"/>
                </StackPanel>
            </Button>
            
            <Button Style="{StaticResource ReelActionStyle}" Click="OnComment">
                <StackPanel>
                    <TextBlock Text="💬" FontSize="24"/>
                    <TextBlock Text="89" FontSize="12"/>
                </StackPanel>
            </Button>
            
            <Button Style="{StaticResource ReelActionStyle}" Click="OnShare">
                <StackPanel>
                    <TextBlock Text="↗️" FontSize="24"/>
                    <TextBlock Text="Share" FontSize="12"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Navigation -->
        <Button Content="✕" 
              Click="OnClose"
              HorizontalAlignment="Left" 
              VerticalAlignment="Top"
              Margin="16"
              Style="{StaticResource CloseButtonStyle}"/>
    </Grid>
</Window>