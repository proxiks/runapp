<UserControl x:Class="RunApp.Desktop.Controls.VerifiedBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="16" Height="16">

    <Grid>
        <Ellipse Fill="#1877F2" Width="16" Height="16"/>
        <Path Data="M5 8l2 2 4-4"
              Stroke="White"
              StrokeThickness="2"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Stretch="Uniform"
              Margin="3"/>
    </Grid>
</UserControl>