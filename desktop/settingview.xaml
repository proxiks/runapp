<UserControl x:Class="RunApp.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600" Margin="0,0,0,40">

            <!-- Header -->
            <TextBlock Text="Settings" 
                     FontSize="24" 
                     FontWeight="Bold" 
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     Margin="16,16,16,24"/>

            <!-- Account Section -->
            <Border Style="{StaticResource SettingsSectionStyle}">
                <StackPanel>
                    <TextBlock Text="Account" 
                             Style="{StaticResource SectionHeaderStyle}"/>
                    
                    <Button Style="{StaticResource SettingsItemStyle}"
                          Click="OnEditProfile">
                        <Grid>
                            <TextBlock Text="Edit Profile" 
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="→" 
                                     HorizontalAlignment="Right"
                                     Foreground="{DynamicResource TextMutedBrush}"/>
                        </Grid>
                    </Button>
                    
                    <Button Style="{StaticResource SettingsItemStyle}"
                          Click="OnChangePassword">
                        <Grid>
                            <TextBlock Text="Change Password" 
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="→" 
                                     HorizontalAlignment="Right"
                                     Foreground="{DynamicResource TextMutedBrush}"/>
                        </Grid>
                    </Button>
                    
                    <Button Style="{StaticResource SettingsItemStyle}"
                          Click="OnPrivacySettings">
                        <Grid>
                            <TextBlock Text="Privacy" 
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="→" 
                                     HorizontalAlignment="Right"
                                     Foreground="{DynamicResource TextMutedBrush}"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Appearance Section -->
            <Border Style="{StaticResource SettingsSectionStyle}"
                    Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Appearance" 
                             Style="{StaticResource SectionHeaderStyle}"/>
                    
                    <!-- Theme Selector -->
                    <StackPanel Margin="0,8">
                        <TextBlock Text="Theme" 
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 FontSize="13"
                                 Margin="16,0,0,8"/>
                        
                        <UniformGrid Columns="2" Margin="12,0">
                            <RadioButton x:Name="ThemeDark"
                                       Content="🌙 Dark"
                                       Checked="OnThemeChanged"
                                       Style="{StaticResource ThemeRadioStyle}"/>
                            <RadioButton x:Name="ThemeLight"
                                       Content="☀️ Light"
                                       Checked="OnThemeChanged"
                                       Style="{StaticResource ThemeRadioStyle}"/>
                            <RadioButton x:Name="ThemeMidnight"
                                       Content="🌑 Midnight"
                                       Checked="OnThemeChanged"
                                       Style="{StaticResource ThemeRadioStyle}"/>
                            <RadioButton x:Name="ThemeOcean"
                                       Content="🌊 Ocean"
                                       Checked="OnThemeChanged"
                                       Style="{StaticResource ThemeRadioStyle}"/>
                        </UniformGrid>
                    </StackPanel>

                    <!-- Font Size -->
                    <StackPanel Margin="0,16,0,8">
                        <Grid Margin="16,0">
                            <TextBlock Text="Font Size" 
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     FontSize="13"/>
                            <TextBlock x:Name="FontSizeValue"
                                     Text="Medium"
                                     HorizontalAlignment="Right"
                                     Foreground="{DynamicResource TextMutedBrush}"/>
                        </Grid>
                        <Slider x:Name="FontSizeSlider"
                              Minimum="12" Maximum="20" Value="14"
                              Margin="16,8"
                              ValueChanged="OnFontSizeChanged"
                              Style="{StaticResource ModernSliderStyle}"/>
                    </StackPanel>

                    <!-- Animations -->
                    <CheckBox x:Name="AnimationsToggle"
                            Content="Enable animations"
                            Margin="16,8"
                            Checked="OnAnimationsToggle"
                            Unchecked="OnAnimationsToggle"
                            Style="{StaticResource ModernCheckBoxStyle}"/>
                </StackPanel>
            </Border>

            <!-- Notifications Section -->
            <Border Style="{StaticResource SettingsSectionStyle}"
                    Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Notifications" 
                             Style="{StaticResource SectionHeaderStyle}"/>
                    
                    <CheckBox x:Name="PushToggle"
                            Content="Push notifications"
                            IsChecked="True"
                            Margin="16,8"
                            Style="{StaticResource ModernCheckBoxStyle}"/>
                    
                    <CheckBox x:Name="EmailToggle"
                            Content="Email notifications"
                            IsChecked="True"
                            Margin="16,8"
                            Style="{StaticResource ModernCheckBoxStyle}"/>
                    
                    <CheckBox x:Name="SoundToggle"
                            Content="Notification sounds"
                            IsChecked="True"
                            Margin="16,8"
                            Style="{StaticResource ModernCheckBoxStyle}"/>
                    
                    <CheckBox x:Name="MentionToggle"
                            Content="Mention alerts"
                            IsChecked="True"
                            Margin="16,8"
                            Style="{StaticResource ModernCheckBoxStyle}"/>
                </StackPanel>
            </Border>

            <!-- Security Section -->
            <Border Style="{StaticResource SettingsSectionStyle}"
                    Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Security" 
                             Style="{StaticResource SectionHeaderStyle}"/>
                    
                    <Button Style="{StaticResource SettingsItemStyle}"
                          Click="OnTwoFactorAuth">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Two-Factor Authentication" 
                                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Enabled via email" 
                                         FontSize="12"
                                         Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                            <TextBlock Text="✓" 
                                     HorizontalAlignment="Right"
                                     Foreground="{DynamicResource SuccessBrush}"/>
                        </Grid>
                    </Button>
                    
                    <Button Style="{StaticResource SettingsItemStyle}"
                          Click="OnActiveSessions">
                        <Grid>
                            <TextBlock Text="Active Sessions" 
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="2 devices" 
                                     HorizontalAlignment="Right"
                                     Foreground="{DynamicResource TextMutedBrush}"/>
                        </Grid>
                    </Button>
                    
                    <Button Style="{StaticResource SettingsItemStyle}"
                          Click="OnLyfronStatus">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Lyfron Security" 
                                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Real-time threat monitoring active" 
                                         FontSize="12"
                                         Foreground="{DynamicResource SuccessBrush}"/>
                            </StackPanel>
                            <TextBlock Text="🛡️" 
                                     HorizontalAlignment="Right"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Danger Zone -->
            <Border Style="{StaticResource SettingsSectionStyle}"
                    Margin="0,16,0,0"
                    BorderBrush="{DynamicResource DangerBrush}">
                <StackPanel>
                    <TextBlock Text="Danger Zone" 
                             Foreground="{DynamicResource DangerBrush}"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Margin="16,12,16,8"/>
                    
                    <Button Style="{StaticResource DangerButtonStyle}"
                          Click="OnLogout">
                        <TextBlock Text="Log Out" HorizontalAlignment="Center"/>
                    </Button>
                    
                    <Button Style="{StaticResource DangerButtonStyle}"
                          Margin="0,8,0,0"
                          Click="OnDeleteAccount">
                        <TextBlock Text="Delete Account" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <TextBlock Text="RunApp v2.0.1 • Built with Lyfron"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="12"
                     HorizontalAlignment="Center"
                     Margin="0,24,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>