<UserControl x:Class="RunApp.Desktop.Controls.AdReelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="100vh">

    <Grid>
        <!-- Video -->
        <MediaElement x:Name="AdVideo"
                     LoadedBehavior="Play"
                     UnloadedBehavior="Stop"
                     Stretch="UniformToFill"/>

        <!-- Dark gradient overlay -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#CC000000" Offset="0.7"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Sponsored label -->
        <Border VerticalAlignment="Top" 
                HorizontalAlignment="Left"
                Margin="16,16,0,0"
                Background="#F02849"
                CornerRadius="4"
                Padding="8,4">
            <TextBlock Text="SPONSORED" 
                     Foreground="White"
                     FontSize="11"
                     FontWeight="Bold"
                     LetterSpacing="1"/>
        </Border>

        <!-- Bottom info -->
        <StackPanel VerticalAlignment="Bottom" 
                   Margin="16,0,80,100">
            
            <!-- Advertiser -->
            <StackPanel Orientation="Horizontal" 
                       Margin="0,0,0,8">
                <Border Width="36" 
                       Height="36" 
                       CornerRadius="8"
                       Background="{DynamicResource AccentBrush}"
                       Margin="0,0,10,0">
                    <TextBlock x:Name="AdvertiserInitial"
                             Foreground="White"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock x:Name="AdvertiserName"
                             Foreground="White"
                             FontWeight="SemiBold"
                             FontSize="15"/>
                    <TextBlock Text="Sponsored"
                             Foreground="#B0B3B8"
                             FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <!-- Headline -->
            <TextBlock x:Name="HeadlineText"
                     Foreground="White"
                     FontSize="18"
                     FontWeight="Bold"
                     TextWrapping="Wrap"
                     Margin="0,0,0,6"/>

            <!-- Description -->
            <TextBlock x:Name="DescriptionText"
                     Foreground="#B0B3B8"
                     FontSize="14"
                     TextWrapping="Wrap"
                     Margin="0,0,0,12"/>

            <!-- CTA Button -->
            <Button x:Name="CtaButton"
                   Click="OnCtaClick"
                   Style="{StaticResource AdCtaStyle}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="CtaText" 
                             Foreground="White"
                             FontWeight="SemiBold"/>
                    <TextBlock Text=" ↗" 
                             Foreground="White"
                             FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Right actions -->
        <StackPanel HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,16,100">
            
            <!-- Like -->
            <Button x:Name="LikeButton"
                   Click="OnLikeClick"
                   Style="{StaticResource AdActionStyle}">
                <StackPanel>
                    <TextBlock x:Name="LikeIcon" 
                             Text="♥" 
                             FontSize="28"
                             Foreground="White"/>
                    <TextBlock x:Name="LikeCount"
                             Text="0"
                             Foreground="White"
                             FontSize="12"
                             HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Share -->
            <Button Click="OnShareClick"
                   Style="{StaticResource AdActionStyle}">
                <StackPanel>
                    <TextBlock Text="↗️" FontSize="24"/>
                    <TextBlock x:Name="ShareCount"
                             Text="0"
                             Foreground="White"
                             FontSize="12"
                             HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Website link -->
            <Button Click="OnWebsiteClick"
                   Style="{StaticResource AdActionStyle}"
                   ToolTip="Visit website">
                <StackPanel>
                    <TextBlock Text="🌐" FontSize="24"/>
                    <TextBlock Text="Website"
                             Foreground="White"
                             FontSize="12"
                             HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Skip indicator -->
        <Border VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,16,16,0">
            <TextBlock x:Name="SkipTimer"
                     Foreground="White"
                     FontSize="13"
                     Background="#80000000"
                     Padding="8,4"
                     CornerRadius="4"/>
        </Border>
    </Grid>
</UserControl>