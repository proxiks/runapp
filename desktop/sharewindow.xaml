<Window x:Class="RunApp.Desktop.Windows.ShareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Share Ad" 
        Height="300" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

    <StackPanel Margin="24">
        <TextBlock Text="Share this ad" 
                 FontSize="20" 
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 Margin="0,0,0,16"/>

        <TextBox x:Name="ShareUrlBox"
               Text="{Binding ShareUrl}"
               IsReadOnly="True"
               Background="{DynamicResource SurfaceHoverBrush}"
               Foreground="{DynamicResource TextPrimaryBrush}"
               Padding="12"
               BorderThickness="0"
               Margin="0,0,0,12"/>

        <Button Content="Copy Link" 
              Click="OnCopy"
              Style="{StaticResource PrimaryButtonStyle}"
              Margin="0,0,0,8"/>

        <Button Content="Share to WhatsApp" 
              Click="OnWhatsApp"
              Style="{StaticResource SecondaryButtonStyle}"
              Margin="0,0,0,8"/>

        <Button Content="Share to Twitter" 
              Click="OnTwitter"
              Style="{StaticResource SecondaryButtonStyle}"
              Margin="0,0,0,8"/>

        <Button Content="Close" 
              Click="OnClose"
              Style="{StaticResource GhostButtonStyle}"/>
    </StackPanel>
</Window>