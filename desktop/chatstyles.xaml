<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Conversation Item -->
    <Style x:Key="ConversationItemStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Message Bubble -->
    <Style x:Key="MessageBubbleStyle" TargetType="Border">
        <Setter Property="MaxWidth" Value="480"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Margin" Value="0,4"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsOwn}" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsOwn}" Value="False">
                <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Send Button -->
    <Style x:Key="SendButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Converters -->
    <local:BoolToOwnForegroundConverter x:Key="OwnToForeground"/>
    <local:BoolToOwnTimeColorConverter x:Key="OwnToTimeColor"/>
    <local:CountToVisibilityConverter x:Key="CountToVisibility"/>
    <local:NullToVisibilityConverter x:Key="NullToVisibility"/>

</ResourceDictionary>