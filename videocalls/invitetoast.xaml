<UserControl x:Class="RunApp.Desktop.Controls.InviteToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="360" Height="180">

    <Border Background="#242526"
          CornerRadius="16"
          BorderBrush="#3A3B3C"
          BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" 
                      Orientation="Horizontal"
                      Margin="0,0,0,8">
                <Border Width="40"
                      Height="40"
                      CornerRadius="20"
                      Background="LinearGradient(135deg, #1877f2, #6b4c9a)"
                      Margin="0,0,12,0">
                    <TextBlock x:Name="InviterInitial"
                             Foreground="White"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="InviterName"
                             Foreground="White"
                             FontWeight="SemiBold"/>
                    <TextBlock x:Name="CallTypeText"
                             Foreground="#B0B3B8"
                             FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <!-- Info -->
            <TextBlock Grid.Row="1"
                     x:Name="ParticipantInfo"
                     Foreground="#65676B"
                     FontSize="13"
                     Margin="0,0,0,12"/>

            <!-- Timer bar -->
            <ProgressBar Grid.Row="1"
                       x:Name="ExpireTimer"
                       Maximum="120"
                       Value="120"
                       Height="3"
                       Background="#3A3B3C"
                       Foreground="#1877F2"
                       Margin="0,0,0,12"/>

            <!-- Actions -->
            <StackPanel Grid.Row="2" 
                      Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="12">
                <Button Content="Decline"
                      Click="OnDecline"
                      Background="#3A3B3C"
                      Foreground="White"
                      Padding="24,10"
                      BorderThickness="0"
                      CornerRadius="20"/>

                <Button Content="Accept"
                      Click="OnAccept"
                      Background="#42B72A"
                      Foreground="White"
                      Padding="24,10"
                      BorderThickness="0"
                      CornerRadius="20"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>